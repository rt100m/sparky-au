---
import Base from '../layouts/Base.astro';
import { BIZ } from '../data/site';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: BIZ.url },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${BIZ.url}/about/` },
  ],
};
---
<Base
  title="About | The Sparky Behind Voltcraft Electrical, Sydney Inner West"
  description="Voltcraft Electrical is one licensed electrician, 12 years on the tools, based in Marrickville. No call centre, no subcontractors — the person who quotes your job does your job."
  schema={[breadcrumb]}
>
  <section class="px-5 md:px-8 pt-16 md:pt-24 pb-20">
    <div class="mx-auto max-w-[860px]">
      <nav aria-label="Breadcrumb" class="mono text-[11px] text-[var(--muted)] tracking-wider">
        <a href="/" class="hover:text-[var(--copper)]">HOME</a> / ABOUT
      </nav>
      <p class="spec-code mt-10 reveal">THE ONE-MAN BAND</p>
      <h1 class="text-5xl md:text-7xl font-extralight mt-4 reveal">You deal with the sparky.<br /><span class="filament font-extrabold">Not a call centre.</span></h1>

      <div class="mt-12 space-y-6 text-[17px] leading-relaxed max-w-[65ch]">
        <p class="reveal">Voltcraft Electrical is one person: a licensed electrician ({BIZ.licence}) with {BIZ.yearsTrading} years on the tools, based in Marrickville and working across Sydney's Inner West.</p>
        <p class="reveal">That is a deliberate choice, not a limitation. The person who answers the phone is the person who quotes the job, does the work, tests the circuits and signs the certificate. Nothing gets lost between a salesperson, a scheduler and whoever turns up.</p>
        <p class="reveal">The trade-off is honest: I book a week or so out for non-urgent work, because I would rather do fewer jobs properly than run a fleet doing them fast. Emergencies still jump the queue, 24/7.</p>
        <p class="reveal">Every job runs the same way — fixed quote before work starts, AS/NZS 3000 wiring rules on the tools, tested before I leave, CCEW certificate in your inbox after. If that sounds like the sparky you have been trying to find, call.</p>
      </div>

      <div class="cert-card p-6 md:p-8 mt-12 reveal">
        <div class="flex justify-between items-baseline border-b border-[var(--hairline)] pb-3">
          <span class="mono text-[11px] tracking-[.14em] text-[var(--muted)]">CREDENTIALS</span>
          <span class="mono text-[11px] text-[#3f6b4f] border border-[#3f6b4f] rounded px-2 -rotate-2 inline-block">CURRENT</span>
        </div>
        <dl class="mt-4 space-y-3 text-[15px]">
          <div class="flex justify-between gap-6"><dt>NSW electrical licence</dt><dd class="mono text-[13px] text-[var(--copper)]">345678C</dd></div>
          <div class="flex justify-between gap-6"><dt>Public liability insurance</dt><dd class="mono text-[13px] text-[var(--copper)]">$20M</dd></div>
          <div class="flex justify-between gap-6"><dt>Years licensed</dt><dd class="mono text-[13px] text-[var(--copper)]">{BIZ.yearsTrading}</dd></div>
          <div class="flex justify-between gap-6"><dt>Standards</dt><dd class="mono text-[13px] text-[var(--copper)]">AS/NZS 3000 · AS 3786</dd></div>
        </dl>
      </div>
    </div>
  </section>
</Base>
